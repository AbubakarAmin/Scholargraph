GOOGLE_API_KEY=
# OpenAlex Configuration (no API key required, just email for rate limiting)
OPENALEX_EMAIL=

# OpenAI API (Optional - for additional LLM capabilities)
# Get from: https://plaAtform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Scite.ai API (Optional - for claim verification)
# Get from: https://scite.ai/api
SCITE_API_KEY=your_scite_api_key_here

# System Configuration
RESEARCH_DOMAIN=computer_science  # or physics, biology, etc.
MAX_ITERATIONS=5
SUPERVISOR_THRESHOLD=8.5
DEBUG_MODE=true
LOG_LEVEL=INFO

# Memory Configuration
VECTOR_DB_PATH=./memory/vector_db
MEMORY_SIZE=100000

# Output Configuration
OUTPUT_DIR=./output
DRAFT_VERSIONS_DIR=./output/draft_versions
DEBATE_LOG_PATH=./output/debate_log.txt
FEEDBACK_LOG_PATH=./output/feedback_log.json 